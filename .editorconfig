root = true

# ============================================================
# 1. 通用設定
# ============================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================
# 2. 後端與編譯語言 (4 格)
# Python, PHP, Java, C, C++, C#, Dart
# ============================================================
[*.{py,php,java,c,cpp,h,hpp,cs,dart}]
indent_style = space
indent_size = 4

# ============================================================
# 3. 前端與現代腳本 (2 格)
# JS, TS, Vue, React, HTML, CSS
# ============================================================
[*.{js,jsx,ts,tsx,vue,html,css,scss,less,json,jsonc}]
indent_style = space
indent_size = 2

# ============================================================
# 4. 系統與雲端基礎設施 (2 格)
# ============================================================
[*.{sql,yml,yaml,sh,bash,zsh,tf,tfvars,toml}]
indent_style = space
indent_size = 2

# Dockerfile 與其變體 (Dockerfile.dev, Dockerfile.prod...)
[{Dockerfile,Dockerfile.*}]
indent_style = space
indent_size = 2

# ============================================================
# 5. 特殊檔案
# ============================================================
[Makefile]
indent_style = tab
indent_size = 8

# Markdown 雙空格換行需保留,故關閉 trim_trailing_whitespace
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
