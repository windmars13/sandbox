{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: 目前檔案",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Pytest（目前檔案）",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal"
    },
    {
      "name": "Node: Vite Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev"
    }
  ]
}
