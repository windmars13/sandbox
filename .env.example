# ============================================================
# 環境變數範本 — 複製為 .env 後填入實際值
# ⚠️  .env 已列入 .gitignore，本檔案可安全提交
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000
APP_URL=http://localhost:3000
DEBUG=false                   # 開啟詳細 log（production 請設 false）

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/dbname
# 或分開設定：
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=myapp
# DB_USER=root
# DB_PASS=

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── External API ─────────────────────────────────────────────
API_KEY=your_key_here
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=

# ── Storage ──────────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=ap-northeast-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
